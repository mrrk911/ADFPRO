{
	"name": "dataflow1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "AzureSqlOrders",
						"type": "DatasetReference"
					},
					"name": "source"
				}
			],
			"sinks": [],
			"transformations": [],
			"scriptLines": [
				"parameters{",
				"     LastWatermark as string",
				"}",
				"source(output(",
				"          OrderID as integer,",
				"          CustomerID as integer,",
				"          OrderDate as date,",
				"          LastModifiedDate as date",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: (SELECT * \\r\\nFROM dbo.Orders \\r\\nWHERE LastModifiedDate > '$LastWatermark'),",
				"     format: 'query') ~> source"
			]
		}
	}
}