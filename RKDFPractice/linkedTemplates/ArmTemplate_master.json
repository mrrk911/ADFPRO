{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "RKDFPractice"
		},
		"ds_csv_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ds_csv'"
		},
		"ls_database_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_database'"
		},
		"ls_datalake_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_datalake'"
		},
		"ls_dfpractice_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_dfpractice'"
		},
		"ls_practice_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_practice'"
		},
		"AzureSqlDbLS_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "rkpracticeserver.database.windows.net"
		},
		"AzureSqlDbLS_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "dfpracticedb"
		},
		"ds_csv_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://dfstoragepractice.dfs.core.windows.net/"
		},
		"ls_REST_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://pokeapi.co/api/v2/pokemon"
		},
		"ls_database_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "adfproramserver.database.windows.net"
		},
		"ls_database_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "adfprodb"
		},
		"ls_database_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "ramadmin"
		},
		"ls_datalake_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adfprostoarge.dfs.core.windows.net/"
		},
		"ls_dfpractice_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://dfstoragepractice.dfs.core.windows.net/"
		},
		"ls_practice_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://dfpracticestorage.dfs.core.windows.net/"
		},
		"schedule_properties_Scheduled_parameters_schema": {
			"type": "string",
			"defaultValue": "source"
		},
		"schedule_properties_Scheduled_parameters_table": {
			"type": "string",
			"defaultValue": "Orders"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "RKDFPractice_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ds_csv_accountKey": {
						"value": "[parameters('ds_csv_accountKey')]"
					},
					"ls_database_password": {
						"value": "[parameters('ls_database_password')]"
					},
					"ls_datalake_accountKey": {
						"value": "[parameters('ls_datalake_accountKey')]"
					},
					"ls_dfpractice_accountKey": {
						"value": "[parameters('ls_dfpractice_accountKey')]"
					},
					"ls_practice_accountKey": {
						"value": "[parameters('ls_practice_accountKey')]"
					},
					"AzureSqlDbLS_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlDbLS_properties_typeProperties_server')]"
					},
					"AzureSqlDbLS_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlDbLS_properties_typeProperties_database')]"
					},
					"ds_csv_properties_typeProperties_url": {
						"value": "[parameters('ds_csv_properties_typeProperties_url')]"
					},
					"ls_REST_properties_typeProperties_url": {
						"value": "[parameters('ls_REST_properties_typeProperties_url')]"
					},
					"ls_database_properties_typeProperties_server": {
						"value": "[parameters('ls_database_properties_typeProperties_server')]"
					},
					"ls_database_properties_typeProperties_database": {
						"value": "[parameters('ls_database_properties_typeProperties_database')]"
					},
					"ls_database_properties_typeProperties_userName": {
						"value": "[parameters('ls_database_properties_typeProperties_userName')]"
					},
					"ls_datalake_properties_typeProperties_url": {
						"value": "[parameters('ls_datalake_properties_typeProperties_url')]"
					},
					"ls_dfpractice_properties_typeProperties_url": {
						"value": "[parameters('ls_dfpractice_properties_typeProperties_url')]"
					},
					"ls_practice_properties_typeProperties_url": {
						"value": "[parameters('ls_practice_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "RKDFPractice_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"schedule_properties_Scheduled_parameters_schema": {
						"value": "[parameters('schedule_properties_Scheduled_parameters_schema')]"
					},
					"schedule_properties_Scheduled_parameters_table": {
						"value": "[parameters('schedule_properties_Scheduled_parameters_table')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'RKDFPractice_ArmTemplate_0')]"
			]
		}
	]
}